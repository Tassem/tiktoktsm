# ─────────────────────────────────────────────────────────────────────────────
# Reel Prompt Studio — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit real secrets to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (managed by Replit or self-hosted)
DATABASE_URL=postgresql://user:password@localhost:5432/reelprompt

# ── Session ──────────────────────────────────────────────────────────────────
# Random secret for signed cookies / session tokens (min 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string

# ── Replit AI Integration (OpenAI-compatible) ────────────────────────────────
# Provided automatically by Replit AI Integration — no manual setup needed
AI_INTEGRATIONS_OPENAI_BASE_URL=https://...
AI_INTEGRATIONS_OPENAI_API_KEY=...

# ── Custom / External AI Providers ───────────────────────────────────────────
# Optional: add your own OpenRouter or custom OpenAI-compatible provider
# (configured via Admin Panel → AI Providers, stored encrypted in DB)

# ── Nano Banana Image Generation ─────────────────────────────────────────────
# API key for the Nano Banana image generation service
# (stored in DB via Admin Panel → AI Providers)
NANO_BANANA_API_KEY=sk-...
NANO_BANANA_BASE_URL=https://apikey.4kmedialive.com/api/nanobanana

# ── Port (set by Replit automatically) ───────────────────────────────────────
PORT=8080
